{
  "name": "karlmaxx-investment-limited",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\"",
    "dev:fresh": "npm run clean && next dev -p 3030",
    "reinstall": "npm run clean && node -e \"try{require('fs').rmSync('node_modules',{recursive:true,force:true})}catch(e){}\" && npm ci",
    "stack:check": "npm run verify:supabase && npm run lint && npm run build",
    "dev": "next dev -p 3030",
    "open:dev": "open http://localhost:3030",
    "dev:karlmaxx": "next dev -p 3030",
    "dev:karlmaxx:webpack": "next dev --webpack -p 3030",
    "build": "next build --webpack",
    "start": "next start",
    "start:karlmaxx": "next start -p 3030",
    "lint": "eslint",
    "verify:supabase": "node scripts/verify-supabase.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.0",
    "axobject-query": "^3.2.4",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "typescript": "^5"
  }
}
