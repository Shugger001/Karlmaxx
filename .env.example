# Copy to `.env.local` (never commit `.env.local`). Restart `npm run dev` after changes.
#
# Apply SQL in order: supabase/migrations (see supabase/MIGRATION_ORDER.txt).
# Smoke test: npm run verify:supabase

# --- Supabase (Dashboard → Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key
# Server only — never NEXT_PUBLIC_. Used for Paystack verify, order writes, sitemap product URLs.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

# --- Paystack ---
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# --- WhatsApp click-to-chat (digits only, no +) ---
NEXT_PUBLIC_WHATSAPP_NUMBER=

# --- Optional: canonical site URL for sitemap, robots, Open Graph ---
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
